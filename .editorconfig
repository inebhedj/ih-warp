root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
quote_type = single
tab_width = 2
trim_trailing_whitespace = true

[*.js]
max_line_length = 80
quote_type = single
semi = true
trailing_comma = none

[*.json]
indent_style = space
indent_size = 2
insert_final_newline = false

[*.md]
max_line_length = 80
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2
